      "title": "Pain Level (1-10)"
    },
    "warm_to_touch": {
      "type": "boolean",
      "title": "Warm to Touch"
    },
    "day_number": {
      "type": "number",
      "title": "Recovery Day Number"
    },
    "ai_result": {
      "type": "string",
      "enum": [
        "normal",
        "monitor",
        "at_risk"
      ],
      "title": "AI Assessment Result"
    },
    "ai_summary": {
      "type": "string",
      "title": "AI Summary Text"
    },
    "contacted_care_team": {
      "type": "boolean",
      "title": "Contacted Care Team"
    },
    "notes": {
      "type": "string",
